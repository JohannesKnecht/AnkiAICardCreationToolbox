{
  "$schema": "https://opencode.ai/config.json",
  "model": "copilot/claude-opus-4.6",
  "small_model": "copilot/claude-opus-4.6",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "copilot/claude-opus-4.6"
    },
    "plan": {
      "mode": "primary",
      "model": "copilot/claude-opus-4.6"
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "copilot/claude-opus-4.6"
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "ask",
      "*.py": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "edit": {
      "*": "ask",
      "*.py": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "grep": {
      "*": "ask",
      "*.py": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "glob": {
      "*": "ask",
      "*.py": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "list": {
      "*": "ask",
      "*.py": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow"
  }
}